{
  "name": "@tuteliq/mcp",
  "mcpName": "ai.tuteliq/mcp",
  "version": "3.15.6",
  "description": "MCP server for Tuteliq — 50 AI-powered tools for child safety, fraud detection, synthetic content forensics, identity verification, grooming, bullying, sextortion, document analysis, and content moderation. Interactive UI widgets for Claude, Cursor, and MCP-compatible AI assistants.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "bin": {
    "tuteliq-mcp": "./dist/src/index.js"
  },
  "files": [
    "dist",
    "dist-ui"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build:server": "tsc",
    "build:ui": "rm -rf dist-ui && WIDGET=detection-result vite build && WIDGET=multi-result vite build && WIDGET=emotions-result vite build && WIDGET=media-result vite build && WIDGET=action-plan vite build && WIDGET=report-result vite build && WIDGET=synthetic-result vite build && WIDGET=incidents-overview vite build && WIDGET=incidents-list vite build && WIDGET=incident-detail vite build && WIDGET=incident-trends vite build",
    "build": "npm run build:ui && npm run build:server",
    "dev:server": "tsx watch server.ts",
    "dev:ui": "vite build --watch",
    "start": "node dist/server.js",
    "start:stdio": "TUTELIQ_MCP_TRANSPORT=stdio node dist/src/index.js",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "tuteliq",
    "mcp",
    "mcp-server",
    "mcp-apps",
    "model-context-protocol",
    "claude",
    "cursor",
    "chatgpt",
    "ai",
    "child-safety",
    "online-safety",
    "content-moderation",
    "trust-safety",
    "bullying-detection",
    "grooming-detection",
    "fraud-detection",
    "social-engineering",
    "romance-scam",
    "sextortion",
    "radicalisation",
    "coercive-control",
    "gambling-harm",
    "vulnerability-detection",
    "document-analysis",
    "pdf-safety",
    "synthetic-content",
    "deepfake-detection",
    "ai-generated",
    "c2pa",
    "identity-verification",
    "age-verification",
    "kosa",
    "dsa",
    "gdpr",
    "interactive-ui",
    "multilingual"
  ],
  "author": "Tuteliq <sales@tuteliq.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tuteliq/mcp.git"
  },
  "homepage": "https://tuteliq.ai",
  "bugs": {
    "url": "https://github.com/Tuteliq/mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@tuteliq/sdk": "^2.13.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.3.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "overrides": {
    "qs": ">=6.15.2",
    "hono": ">=4.12.12",
    "@hono/node-server": ">=1.19.13",
    "path-to-regexp": ">=8.2.0",
    "fast-uri": ">=3.1.2",
    "ip-address": ">=10.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
