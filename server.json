{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "ai.tuteliq/mcp",
  "description": "Detect grooming, bullying, fraud, and 16+ online threats across text, voice, image, and video.",
  "repository": {
    "url": "https://github.com/Tuteliq/mcp",
    "source": "github"
  },
  "version": "3.13.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@tuteliq/mcp",
      "version": "3.13.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Tuteliq API key from tuteliq.ai",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "TUTELIQ_API_KEY"
        }
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://api.tuteliq.ai/mcp"
    }
  ]
}
